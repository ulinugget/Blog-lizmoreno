{
  "name": "astro-sanity-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "studio:dev": "pnpm --filter studio dev",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "typegen": "pnpm --filter studio typegen && pnpm exec sanity typegen generate"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
