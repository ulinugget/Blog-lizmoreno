---
import { client } from "../lib/sanity/client";
import { postsQuery } from "../lib/sanity/queries";
import type { Post } from "../types";
import Footer from "../components/Footer.astro";

const allPosts = await client.fetch<Post[]>(postsQuery);
const latestPost = allPosts[0];
const otherPosts = allPosts.slice(1);
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>El baul de los recuerdos</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Oranienbaum&display=swap" rel="stylesheet" />
    <style>
      body { font-family: 'Libre Baskerville', serif; font-weight: 400; }
      .no-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </head>
  <body class="bg-palette-lightest text-palette-darkest h-screen flex flex-col overflow-hidden">
    <!-- Navbar -->
    <nav class="absolute top-0 left-0 w-full z-50 p-6">
      <div class="max-w-7xl mx-auto flex justify-start items-center gap-4">
        <a href="/" class="text-white bg-black/20 hover:bg-black/40 border border-white/20 p-3 rounded-full backdrop-blur-md transition" aria-label="Home">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="w-8 h-8">
            <rect width="256" height="256" fill="none"/>
            <line x1="128" y1="232" x2="128" y2="176" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
            <path d="M48,56h0a80,80,0,0,1,80,80v40a0,0,0,0,1,0,0h0A80,80,0,0,1,48,96V56A0,0,0,0,1,48,56Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
            <path d="M208,56h0a0,0,0,0,1,0,0V96a80,80,0,0,1-80,80h0a0,0,0,0,1,0,0V136a80,80,0,0,1,80-80Z" transform="translate(336 232) rotate(180)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
            <polyline points="80 208 128 232 176 208" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
            <path d="M86.77,66C100,38,128,24,128,24s28,14,41.23,42" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
          </svg>
        </a>
        <span class="text-white text-2xl tracking-md drop-shadow-md" style="font-family: 'Oranienbaum', serif;">
          El baúl de los recuerdos
        </span>
      </div>
    </nav>

    {latestPost ? (
      <main class="flex-1 flex flex-col min-h-0">
        <!-- Hero Section -->
        <section class="relative w-full flex-1 flex items-center justify-center min-h-0 pt-20">
          {latestPost.coverImageUrl ? (
            <div 
              class="absolute inset-0 bg-cover bg-center"
              style={`background-image: url('${latestPost.coverImageUrl}');`}
            >
              <div class="absolute inset-0 bg-black/50"></div>
            </div>
          ) : (
            <div class="absolute inset-0 bg-palette-medium"></div>
          )}
          <div class="relative z-10 w-full max-w-7xl mx-auto px-4 flex flex-col items-start text-left">
            <h1 class="text-4xl md:text-6xl lg:text-7xl text-white font-bold mb-6 drop-shadow-lg leading-tight max-w-4xl" style="font-family: 'Oranienbaum', serif;">
              {latestPost.title}
            </h1>
            <a 
              href={`/posts/${latestPost.slug}`}
              class="inline-block bg-palette-light text-white px-8 py-3 rounded-full text-lg font-semibold hover:bg-palette-medium transition-all shadow-xl"
            >
              Leer
            </a>
          </div>
        </section>

        <!-- Carousel Section -->
        {otherPosts.length > 0 && (
          <section class="max-w-7xl mx-auto w-full px-4 py-6 flex-shrink-0">
            <div class="flex justify-between items-end mb-4 border-b border-palette-light/20 pb-2">
              <h2 class="text-4xl text-palette-darkest font-bold" style="font-family: 'Oranienbaum', serif;">Más historias</h2>
              <div class="flex gap-3">
                <button id="scrollLeftBtn" class="p-3 rounded-full bg-white shadow-sm border border-palette-light/30 text-palette-darkest hover:bg-palette-light hover:text-white transition-colors" aria-label="Anterior">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                  </svg>
                </button>
                <button id="scrollRightBtn" class="p-3 rounded-full bg-white shadow-sm border border-palette-light/30 text-palette-darkest hover:bg-palette-light hover:text-white transition-colors" aria-label="Siguiente">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                  </svg>
                </button>
              </div>
            </div>

            <div class="relative">
              <div id="carousel" class="flex gap-6 overflow-x-auto no-scrollbar scroll-smooth snap-x snap-mandatory pb-8">
                {otherPosts.map((post) => (
                  <a 
                    href={`/posts/${post.slug}`}
                    class="relative flex-none w-[85vw] md:w-[350px] lg:w-[400px] h-[25vh] min-h-[200px] max-h-[260px] rounded-md overflow-hidden group snap-start shadow-lg transition-all"
                  >
                    {post.coverImageUrl ? (
                      <div 
                        class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105"
                        style={`background-image: url('${post.coverImageUrl}');`}
                      >
                        <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/20 to-transparent"></div>
                      </div>
                    ) : (
                      <div class="absolute inset-0 bg-palette-medium transition-transform duration-700 group-hover:scale-105">
                        <div class="absolute inset-0 bg-gradient-to-b from-black/60 to-transparent"></div>
                      </div>
                    )}
                    <div class="relative z-10 p-6 h-full flex flex-col justify-start">
                      <h3 class="text-2xl lg:text-3xl text-white font-bold leading-snug drop-shadow-md" style="font-family: 'Oranienbaum', serif;">
                        {post.title}
                      </h3>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </section>
        )}
      </main>
    ) : (
      <main class="flex-grow flex items-center justify-center">
        <p class="text-palette-medium text-xl">No hay publicaciones a&uacute;n.</p>
      </main>
    )}

    <Footer class="py-3 flex-shrink-0" />

    <script>
      const carousel = document.getElementById('carousel');
      const btnLeft = document.getElementById('scrollLeftBtn');
      const btnRight = document.getElementById('scrollRightBtn');

      if (carousel && btnLeft && btnRight) {
        const getScrollAmount = () => {
          const firstChild = carousel.firstElementChild as HTMLElement;
          if (firstChild) {
            const style = window.getComputedStyle(carousel);
            const gap = parseFloat(style.gap) || 24;
            return firstChild.offsetWidth + gap;
          }
          return 300;
        };

        btnLeft.addEventListener('click', () => {
          carousel.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
        });

        btnRight.addEventListener('click', () => {
          carousel.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
        });
      }
    </script>
  </body>
</html>
